/* 做菜历史页面样式 */
.container {
  min-height: 100vh;
  background: #FAFAF8;
  padding: 20rpx;
}

.empty {
  display: flex;
  flex-direction: column;
  align-items: center;
  justify-content: center;
  padding-top: 300rpx;
}

.empty-icon {
  font-size: 80rpx;
  margin-bottom: 30rpx;
}

.empty-text {
  font-size: 28rpx;
  color: #999;
  margin-bottom: 40rpx;
}

.empty-btn {
  padding: 16rpx 48rpx;
  background: #1A1A1A;
  color: #FFF;
  border-radius: 40rpx;
  font-size: 28rpx;
}

.list {
  display: flex;
  flex-direction: column;
  gap: 16rpx;
}

.item {
  background: #FFFFFF;
  border-radius: 16rpx;
  padding: 24rpx;
  position: relative;
}

.item-main {
  display: flex;
  justify-content: space-between;
  align-items: flex-start;
}

.item-image {
  width: 120rpx;
  height: 120rpx;
  border-radius: 12rpx;
  flex-shrink: 0;
  margin-right: 20rpx;
}

.item-left {
  flex: 1;
  display: flex;
  flex-direction: column;
  gap: 8rpx;
}

.item-name {
  font-size: 30rpx;
  font-weight: 600;
  color: #1A1A1A;
}

.item-time {
  font-size: 22rpx;
  color: #8A8A8A;
}

.item-rating {
  display: flex;
  gap: 4rpx;
}

.star {
  font-size: 24rpx;
  color: #D4943A;
}

.item-right {
  display: flex;
  align-items: center;
}

.cook-time {
  font-size: 24rpx;
  color: #8A8A8A;
  background: #F5F5F3;
  padding: 6rpx 16rpx;
  border-radius: 8rpx;
}

.item-note {
  margin-top: 16rpx;
  padding-top: 16rpx;
  border-top: 1rpx solid #F0F0F0;
}

.item-note text {
  font-size: 24rpx;
  color: #8A8A8A;
}

.item-delete {
  position: absolute;
  top: 24rpx;
  right: 24rpx;
  width: 40rpx;
  height: 40rpx;
  display: flex;
  align-items: center;
  justify-content: center;
}

.delete-icon {
  font-size: 28rpx;
}

.load-more, .loading {
  text-align: center;
  padding: 30rpx;
}

.load-more text, .loading text {
  font-size: 26rpx;
  color: #8A8A8A;
}
