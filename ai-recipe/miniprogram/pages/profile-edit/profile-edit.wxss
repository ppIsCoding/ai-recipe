/* 个人信息编辑页面样式 */

.container {
  padding: 0 32rpx 40rpx;
  background: #FBF7F4;
  min-height: 100vh;
}

.form-section {
  background: #fff;
  border-radius: 16rpx;
  padding: 24rpx;
  margin-top: 24rpx;
  box-shadow: 0 4rpx 12rpx rgba(0,0,0,0.08);
}

.form-title {
  font-size: 30rpx;
  font-weight: 700;
  color: #333;
  margin-bottom: 20rpx;
}

.form-group {
  margin-bottom: 24rpx;
}

.form-group:last-child {
  margin-bottom: 0;
}

.form-label {
  font-size: 26rpx;
  color: #666;
  margin-bottom: 12rpx;
  display: block;
}

.form-input {
  height: 80rpx;
  background: #F5F5F5;
  border-radius: 12rpx;
  padding: 0 24rpx;
  font-size: 28rpx;
}

/* 性别选择 */
.gender-options {
  display: flex;
  gap: 16rpx;
}

.gender-btn {
  flex: 1;
  padding: 20rpx;
  background: #F5F5F5;
  border-radius: 12rpx;
  text-align: center;
  border: 2rpx solid #E0E0E0;
}

.gender-btn.active {
  background: #E8722A;
  border-color: #E8722A;
}

.gender-btn text {
  font-size: 28rpx;
  color: #666;
}

.gender-btn.active text {
  color: #fff;
  font-weight: 600;
}

/* 活动量选择 */
.activity-options {
  display: flex;
  flex-direction: column;
  gap: 12rpx;
}

.activity-item {
  display: flex;
  align-items: center;
  justify-content: space-between;
  padding: 20rpx;
  background: #F5F5F5;
  border-radius: 12rpx;
  border: 2rpx solid #E0E0E0;
}

.activity-item.active {
  background: #FFF3E0;
  border-color: #E8722A;
}

.activity-info {
  display: flex;
  flex-direction: column;
  gap: 4rpx;
}

.activity-label {
  font-size: 28rpx;
  font-weight: 600;
  color: #333;
}

.activity-desc {
  font-size: 22rpx;
  color: #999;
}

.activity-check {
  width: 40rpx;
  height: 40rpx;
  background: #E8722A;
  border-radius: 50%;
  display: flex;
  align-items: center;
  justify-content: center;
}

.activity-check text {
  font-size: 24rpx;
  color: #fff;
}

/* 健康目标选择 */
.goal-options {
  display: flex;
  gap: 16rpx;
}

.goal-item {
  flex: 1;
  display: flex;
  flex-direction: column;
  align-items: center;
  gap: 8rpx;
  padding: 24rpx 16rpx;
  background: #F5F5F5;
  border-radius: 12rpx;
  border: 2rpx solid #E0E0E0;
}

.goal-item.active {
  background: #FFF3E0;
  border-color: #E8722A;
}

.goal-icon {
  font-size: 40rpx;
}

.goal-label {
  font-size: 24rpx;
  color: #666;
}

.goal-item.active .goal-label {
  color: #E8722A;
  font-weight: 600;
}

/* 说明 */
.form-tip {
  margin-top: 24rpx;
  padding: 20rpx;
  background: #FFF8F0;
  border-radius: 12rpx;
}

.tip-text {
  font-size: 22rpx;
  color: #999;
  line-height: 1.5;
}

/* 保存按钮 */
.btn-save {
  background: linear-gradient(135deg, #E8722A, #F5A623);
  border-radius: 16rpx;
  padding: 28rpx;
  text-align: center;
  margin-top: 40rpx;
  box-shadow: 0 4rpx 12rpx rgba(232,114,42,0.3);
}

.btn-save text {
  font-size: 32rpx;
  font-weight: 700;
  color: #fff;
}
