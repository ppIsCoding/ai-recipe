/* 个人中心页面样式 */

.container {
  padding: 0 32rpx 40rpx;
  background: #FBF7F4;
  min-height: 100vh;
}

/* 用户信息区域 */
.user-section {
  background: linear-gradient(135deg, #E8722A, #F5A623);
  border-radius: 24rpx;
  padding: 40rpx;
  margin-bottom: 24rpx;
  margin-top: 20rpx;
}

.user-info {
  display: flex;
  align-items: center;
  gap: 24rpx;
}

.user-avatar {
  width: 100rpx;
  height: 100rpx;
  border-radius: 50%;
  border: 4rpx solid rgba(255,255,255,0.5);
}

.user-details {
  display: flex;
  flex-direction: column;
  gap: 8rpx;
}

.user-name {
  font-size: 36rpx;
  font-weight: 700;
  color: #fff;
}

.user-health-goal {
  font-size: 24rpx;
  color: rgba(255,255,255,0.9);
}

.login-prompt {
  display: flex;
  align-items: center;
  gap: 24rpx;
}

.login-avatar {
  width: 100rpx;
  height: 100rpx;
  border-radius: 50%;
  border: 4rpx solid rgba(255,255,255,0.5);
  opacity: 0.7;
}

.login-text {
  font-size: 32rpx;
  font-weight: 600;
  color: #fff;
}

/* BMI 卡片 */
.bmi-card {
  background: #fff;
  border-radius: 16rpx;
  padding: 24rpx;
  margin-bottom: 24rpx;
  box-shadow: 0 4rpx 12rpx rgba(0,0,0,0.08);
}

.bmi-header {
  display: flex;
  justify-content: space-between;
  align-items: center;
  margin-bottom: 16rpx;
}

.bmi-title {
  font-size: 28rpx;
  font-weight: 600;
  color: #333;
}

.bmi-more {
  font-size: 24rpx;
  color: #E8722A;
}

.bmi-content {
  display: flex;
  align-items: center;
  justify-content: space-between;
  margin-bottom: 16rpx;
}

.bmi-main {
  display: flex;
  align-items: baseline;
  gap: 8rpx;
}

.bmi-value {
  font-size: 56rpx;
  font-weight: 700;
  color: #333;
}

.bmi-label {
  font-size: 24rpx;
  color: #999;
}

.bmi-status {
  padding: 8rpx 20rpx;
  border-radius: 16rpx;
  font-size: 24rpx;
  font-weight: 600;
}

.bmi-status.underweight {
  background: #E3F2FD;
  color: #1976D2;
}

.bmi-status.normal {
  background: #E8F5E9;
  color: #388E3C;
}

.bmi-status.overweight {
  background: #FFF3E0;
  color: #E65100;
}

.bmi-status.obese {
  background: #FFEBEE;
  color: #C62828;
}

.bmi-footer {
  display: flex;
  justify-content: space-between;
  align-items: center;
  padding-top: 16rpx;
  border-top: 2rpx solid #F5F5F5;
}

.calories-label {
  font-size: 24rpx;
  color: #999;
}

.calories-value {
  font-size: 28rpx;
  font-weight: 600;
  color: #E8722A;
}

/* 未填写个人信息提示 */
.profile-hint {
  display: flex;
  align-items: center;
  justify-content: space-between;
  background: #fff;
  border-radius: 16rpx;
  padding: 24rpx;
  margin-bottom: 24rpx;
  box-shadow: 0 4rpx 12rpx rgba(0,0,0,0.08);
}

.hint-content {
  display: flex;
  align-items: center;
  gap: 16rpx;
}

.hint-icon {
  font-size: 40rpx;
}

.hint-text {
  display: flex;
  flex-direction: column;
  gap: 4rpx;
}

.hint-title {
  font-size: 28rpx;
  font-weight: 600;
  color: #333;
}

.hint-desc {
  font-size: 22rpx;
  color: #999;
}

.hint-arrow {
  font-size: 28rpx;
  color: #ccc;
}

/* 统计数据 */
.stats-section {
  display: flex;
  background: #fff;
  border-radius: 16rpx;
  padding: 32rpx 20rpx;
  margin-bottom: 24rpx;
  box-shadow: 0 4rpx 12rpx rgba(0,0,0,0.08);
}

.stat-item {
  flex: 1;
  display: flex;
  flex-direction: column;
  align-items: center;
  gap: 8rpx;
}

.stat-divider {
  width: 2rpx;
  height: 60rpx;
  background: #E0E0E0;
}

.stat-value {
  font-size: 40rpx;
  font-weight: 700;
  color: #E8722A;
}

.stat-label {
  font-size: 24rpx;
  color: #999;
}

/* 功能菜单 */
.menu-section {
  background: #fff;
  border-radius: 16rpx;
  margin-bottom: 24rpx;
  overflow: hidden;
  box-shadow: 0 4rpx 12rpx rgba(0,0,0,0.08);
}

.menu-item {
  display: flex;
  align-items: center;
  padding: 28rpx 24rpx;
  border-bottom: 2rpx solid #F5F5F5;
}

.menu-item:last-child {
  border-bottom: none;
}

.menu-icon {
  font-size: 36rpx;
  margin-right: 16rpx;
}

.menu-text {
  flex: 1;
  font-size: 28rpx;
  color: #333;
}

.menu-arrow {
  font-size: 28rpx;
  color: #ccc;
}

/* 膳食指南标识 */
.guide-badge {
  text-align: center;
  padding: 24rpx;
}

.guide-badge-text {
  font-size: 22rpx;
  color: #ccc;
}

/* 偏好设置弹窗 */
.modal-mask {
  position: fixed;
  top: 0;
  left: 0;
  right: 0;
  bottom: 0;
  background: rgba(0,0,0,0.5);
  display: flex;
  align-items: flex-end;
  z-index: 1000;
}

.modal-content {
  width: 100%;
  background: #fff;
  border-radius: 24rpx 24rpx 0 0;
  padding: 32rpx;
  max-height: 80vh;
  overflow-y: auto;
}

.modal-header {
  display: flex;
  justify-content: space-between;
  align-items: center;
  margin-bottom: 32rpx;
}

.modal-title {
  font-size: 32rpx;
  font-weight: 700;
  color: #333;
}

.modal-close {
  width: 56rpx;
  height: 56rpx;
  display: flex;
  align-items: center;
  justify-content: center;
  background: #F5F5F5;
  border-radius: 50%;
}

.modal-close text {
  font-size: 32rpx;
  color: #999;
}

.preference-section {
  margin-bottom: 32rpx;
}

.preference-label {
  font-size: 28rpx;
  font-weight: 600;
  color: #333;
  margin-bottom: 16rpx;
  display: block;
}

.preference-tags {
  display: flex;
  flex-wrap: wrap;
  gap: 16rpx;
}

.preference-tag {
  padding: 16rpx 28rpx;
  background: #F5F5F5;
  border-radius: 32rpx;
  border: 2rpx solid #E0E0E0;
}

.preference-tag.selected {
  background: #E8722A;
  border-color: #E8722A;
}

.preference-tag text {
  font-size: 26rpx;
  color: #666;
}

.preference-tag.selected text {
  color: #fff;
}

.btn-save {
  background: linear-gradient(135deg, #E8722A, #F5A623);
  border-radius: 16rpx;
  padding: 24rpx;
  text-align: center;
  margin-top: 16rpx;
}

.btn-save text {
  font-size: 30rpx;
  font-weight: 700;
  color: #fff;
}
