/* 健康分析页面样式 */

.container {
  padding: 0 32rpx 40rpx;
  background: #FBF7F4;
  min-height: 100vh;
}

/* 加载中 */
.loading-section {
  display: flex;
  flex-direction: column;
  align-items: center;
  justify-content: center;
  padding: 120rpx 0;
}

.loading-spinner {
  width: 60rpx;
  height: 60rpx;
  border: 4rpx solid #E0E0E0;
  border-top-color: #E8722A;
  border-radius: 50%;
  animation: spin 1s linear infinite;
}

@keyframes spin {
  to { transform: rotate(360deg); }
}

.loading-text {
  font-size: 28rpx;
  color: #999;
  margin-top: 16rpx;
}

/* 空状态 */
.empty-section {
  display: flex;
  flex-direction: column;
  align-items: center;
  padding: 120rpx 0;
}

.empty-icon {
  font-size: 80rpx;
  margin-bottom: 24rpx;
}

.empty-title {
  font-size: 32rpx;
  font-weight: 700;
  color: #333;
  margin-bottom: 12rpx;
}

.empty-desc {
  font-size: 26rpx;
  color: #999;
  text-align: center;
  margin-bottom: 40rpx;
}

.btn-edit {
  background: linear-gradient(135deg, #E8722A, #F5A623);
  border-radius: 16rpx;
  padding: 24rpx 60rpx;
}

.btn-edit text {
  font-size: 28rpx;
  font-weight: 600;
  color: #fff;
}

/* 分析内容 */
.analysis-content {
  padding-top: 20rpx;
}

/* BMI 卡片 */
.bmi-card {
  background: #fff;
  border-radius: 16rpx;
  padding: 32rpx;
  margin-bottom: 24rpx;
  box-shadow: 0 4rpx 12rpx rgba(0,0,0,0.08);
}

.bmi-header {
  margin-bottom: 24rpx;
}

.bmi-title {
  font-size: 32rpx;
  font-weight: 700;
  color: #333;
  display: block;
}

.bmi-subtitle {
  font-size: 22rpx;
  color: #999;
}

.bmi-main {
  display: flex;
  align-items: center;
  justify-content: space-between;
  margin-bottom: 32rpx;
}

.bmi-value-wrapper {
  display: flex;
  align-items: baseline;
  gap: 8rpx;
}

.bmi-value {
  font-size: 72rpx;
  font-weight: 700;
  color: #333;
}

.bmi-unit {
  font-size: 24rpx;
  color: #999;
}

.bmi-status {
  padding: 12rpx 24rpx;
  border-radius: 16rpx;
  font-size: 28rpx;
  font-weight: 600;
}

.bmi-status.underweight {
  background: #E3F2FD;
  color: #1976D2;
}

.bmi-status.normal {
  background: #E8F5E9;
  color: #388E3C;
}

.bmi-status.overweight {
  background: #FFF3E0;
  color: #E65100;
}

.bmi-status.obese {
  background: #FFEBEE;
  color: #C62828;
}

.bmi-scale {
  display: flex;
  gap: 8rpx;
  margin-bottom: 16rpx;
}

.scale-item {
  flex: 1;
  display: flex;
  flex-direction: column;
  align-items: center;
  gap: 4rpx;
  padding: 12rpx 8rpx;
  border-radius: 8rpx;
}

.scale-item.underweight {
  background: #E3F2FD;
}

.scale-item.normal {
  background: #E8F5E9;
}

.scale-item.overweight {
  background: #FFF3E0;
}

.scale-item.obese {
  background: #FFEBEE;
}

.scale-item text {
  font-size: 20rpx;
  color: #666;
}

.bmi-note {
  font-size: 20rpx;
  color: #ccc;
  display: block;
}

/* 代谢数据 */
.metabolism-card {
  background: #fff;
  border-radius: 16rpx;
  padding: 32rpx;
  margin-bottom: 24rpx;
  box-shadow: 0 4rpx 12rpx rgba(0,0,0,0.08);
}

.card-title {
  font-size: 30rpx;
  font-weight: 700;
  color: #333;
  margin-bottom: 24rpx;
}

.metabolism-grid {
  display: flex;
  gap: 16rpx;
}

.metabolism-item {
  flex: 1;
  display: flex;
  flex-direction: column;
  align-items: center;
  gap: 8rpx;
  padding: 20rpx 12rpx;
  background: #F5F5F5;
  border-radius: 12rpx;
}

.metabolism-item.highlight {
  background: #FFF3E0;
  border: 2rpx solid #E8722A;
}

.metabolism-value {
  font-size: 36rpx;
  font-weight: 700;
  color: #333;
}

.metabolism-item.highlight .metabolism-value {
  color: #E8722A;
}

.metabolism-label {
  font-size: 22rpx;
  color: #999;
}

.metabolism-unit {
  font-size: 20rpx;
  color: #ccc;
}

/* 营养目标 */
.nutrition-card {
  background: #fff;
  border-radius: 16rpx;
  padding: 32rpx;
  margin-bottom: 24rpx;
  box-shadow: 0 4rpx 12rpx rgba(0,0,0,0.08);
}

.nutrition-grid {
  display: flex;
  gap: 16rpx;
}

.nutrition-item {
  flex: 1;
  display: flex;
  flex-direction: column;
  align-items: center;
  gap: 12rpx;
  padding: 24rpx 12rpx;
  background: #F5F5F5;
  border-radius: 12rpx;
}

.nutrition-icon {
  font-size: 40rpx;
}

.nutrition-label {
  font-size: 24rpx;
  color: #999;
}

.nutrition-value {
  font-size: 26rpx;
  font-weight: 600;
  color: #333;
}

/* 健康建议 */
.advice-card {
  background: #fff;
  border-radius: 16rpx;
  padding: 32rpx;
  margin-bottom: 24rpx;
  box-shadow: 0 4rpx 12rpx rgba(0,0,0,0.08);
}

.advice-list {
  display: flex;
  flex-direction: column;
  gap: 16rpx;
}

.advice-item {
  display: flex;
  gap: 12rpx;
  align-items: flex-start;
}

.advice-icon {
  width: 32rpx;
  height: 32rpx;
  background: #E8F5E9;
  border-radius: 50%;
  display: flex;
  align-items: center;
  justify-content: center;
  font-size: 20rpx;
  color: #388E3C;
  flex-shrink: 0;
}

.advice-text {
  font-size: 26rpx;
  color: #666;
  line-height: 1.5;
}

/* 膳食指南 */
.guide-card {
  background: linear-gradient(135deg, #FFF8F0, #FFF3E0);
  border-radius: 16rpx;
  padding: 32rpx;
  margin-bottom: 24rpx;
}

.guide-list {
  display: flex;
  flex-direction: column;
  gap: 16rpx;
}

.guide-item {
  display: flex;
  gap: 12rpx;
  align-items: flex-start;
}

.guide-icon {
  font-size: 24rpx;
  flex-shrink: 0;
}

.guide-text {
  font-size: 24rpx;
  color: #666;
  line-height: 1.5;
}

/* 编辑按钮 */
.btn-edit-profile {
  background: #fff;
  border-radius: 16rpx;
  padding: 28rpx;
  text-align: center;
  border: 2rpx solid #E8722A;
  margin-bottom: 40rpx;
}

.btn-edit-profile text {
  font-size: 28rpx;
  font-weight: 600;
  color: #E8722A;
}
