/* 拍照识别页面样式 - 温暖有机美食风格 */

/* 提示栏 */
.tip-bar {
  background: linear-gradient(135deg, #FFF3E0, #FFE0B2);
  padding: 24rpx 28rpx;
  text-align: center;
  border-radius: var(--radius-lg);
  margin-bottom: 28rpx;
  border: 2rpx solid rgba(232, 114, 42, 0.2);
  animation: fadeInUp 0.6s ease-out;
}

.tip-text {
  font-size: 26rpx;
  color: var(--color-primary-dark);
  font-weight: 500;
  letter-spacing: 1rpx;
}

/* 相机区域 */
.camera-area {
  width: 100%;
  height: 500rpx;
  border-radius: var(--radius-xl);
  overflow: hidden;
  margin-bottom: 36rpx;
  background: linear-gradient(135deg, #1a1a1a, #2d2d2d);
  position: relative;
  box-shadow: var(--shadow-xl);
  animation: fadeInUp 0.6s ease-out 0.1s both;
}

.camera-preview {
  width: 100%;
  height: 100%;
}

.camera-overlay {
  width: 100%;
  height: 100%;
  display: flex;
  align-items: center;
  justify-content: center;
  background: radial-gradient(circle at center, transparent 60%, rgba(0,0,0,0.3) 100%);
}

.scan-frame {
  width: 400rpx;
  height: 400rpx;
  border: 4rpx solid rgba(232, 114, 42, 0.8);
  border-radius: var(--radius-xl);
  background: transparent;
  position: relative;
}

.scan-frame::before {
  content: '';
  position: absolute;
  top: -16rpx;
  left: -16rpx;
  right: -16rpx;
  bottom: -16rpx;
  border: 2rpx dashed rgba(232, 114, 42, 0.4);
  border-radius: 48rpx;
  animation: pulse 2s ease-in-out infinite;
}

.image-preview {
  width: 100%;
  height: 100%;
  object-fit: cover;
}

.empty-camera {
  width: 100%;
  height: 100%;
  display: flex;
  flex-direction: column;
  align-items: center;
  justify-content: center;
  background: linear-gradient(135deg, #f5f5f5, #e8e8e8);
}

.empty-camera image {
  width: 120rpx;
  height: 120rpx;
  opacity: 0.4;
  margin-bottom: 24rpx;
}

.empty-camera text {
  font-size: 28rpx;
  color: var(--color-text-muted);
  font-weight: 500;
}

/* 操作按钮 */
.action-buttons {
  display: flex;
  justify-content: center;
  align-items: flex-start;
  gap: 80rpx;
  margin-bottom: 36rpx;
  animation: fadeInUp 0.6s ease-out 0.2s both;
}

.btn-action {
  display: flex;
  flex-direction: column;
  align-items: center;
  gap: 12rpx;
}

.btn-icon-wrapper {
  width: 100rpx;
  height: 100rpx;
  border-radius: 50%;
  background: var(--color-surface);
  border: 3rpx solid var(--color-border);
  display: flex;
  align-items: center;
  justify-content: center;
  box-shadow: var(--shadow-md);
  transition: all 0.3s ease;
}

.btn-icon-wrapper image {
  width: 50rpx;
  height: 50rpx;
}

.btn-icon-wrapper:active {
  transform: scale(0.95);
  box-shadow: var(--shadow-sm);
}

.btn-label {
  font-size: 24rpx;
  color: var(--color-text-secondary);
  font-weight: 500;
}

.btn-capture-wrapper {
  margin-top: -10rpx;
}

.btn-capture {
  width: 120rpx;
  height: 120rpx;
  border-radius: 50%;
  background: var(--color-surface);
  border: 6rpx solid var(--color-primary);
  display: flex;
  align-items: center;
  justify-content: center;
  box-shadow: var(--shadow-xl);
  transition: all 0.3s ease;
}

.btn-capture:active {
  transform: scale(0.95);
}

.capture-inner {
  width: 90rpx;
  height: 90rpx;
  background: linear-gradient(135deg, var(--color-primary), var(--color-primary-light));
  border-radius: 50%;
  box-shadow: inset 0 4rpx 8rpx rgba(0,0,0,0.2);
}

/* 识别按钮 */
.recognize-btn {
  background: linear-gradient(135deg, var(--color-primary) 0%, var(--color-primary-light) 100%);
  border-radius: var(--radius-xl);
  padding: 28rpx;
  display: flex;
  align-items: center;
  justify-content: center;
  margin-bottom: 40rpx;
  box-shadow: var(--shadow-xl);
  position: relative;
  overflow: hidden;
  animation: fadeInUp 0.6s ease-out 0.3s both;
  transition: all 0.3s ease;
}

.recognize-btn::before {
  content: '';
  position: absolute;
  top: 0;
  left: 0;
  right: 0;
  bottom: 0;
  background: linear-gradient(135deg, rgba(255,255,255,0.2) 0%, transparent 100%);
}

.recognize-btn:active {
  transform: scale(0.98);
  box-shadow: var(--shadow-lg);
}

.recognize-text {
  font-size: 34rpx;
  font-weight: 700;
  color: #fff;
  margin-right: 16rpx;
  letter-spacing: 4rpx;
  position: relative;
  z-index: 1;
  text-shadow: 0 2rpx 4rpx rgba(0,0,0,0.1);
}

.loading-spinner {
  width: 40rpx;
  height: 40rpx;
  border: 4rpx solid rgba(255, 255, 255, 0.3);
  border-top: 4rpx solid #fff;
  border-radius: 50%;
  animation: spin 1s linear infinite;
  position: relative;
  z-index: 1;
}

/* 提示信息 */
.tips-section {
  background: var(--color-surface);
  border-radius: var(--radius-lg);
  padding: 28rpx;
  box-shadow: var(--shadow-md);
  border: 2rpx solid var(--color-border);
  animation: fadeInUp 0.6s ease-out 0.4s both;
}

.tips-title {
  font-size: 30rpx;
  font-weight: 700;
  color: var(--color-text-primary);
  margin-bottom: 20rpx;
  letter-spacing: 2rpx;
  display: flex;
  align-items: center;
}

.tips-title::before {
  content: '💡';
  margin-right: 12rpx;
  font-size: 32rpx;
}

.tips-list {
  display: flex;
  flex-direction: column;
  gap: 16rpx;
}

.tip-item {
  display: flex;
  align-items: center;
  gap: 16rpx;
  padding: 12rpx 0;
  border-bottom: 2rpx solid var(--color-border);
}

.tip-item:last-child {
  border-bottom: none;
}

.tip-icon {
  width: 44rpx;
  height: 44rpx;
  background: linear-gradient(135deg, #FFF3E0, #FFE0B2);
  color: var(--color-primary);
  border-radius: 50%;
  display: flex;
  align-items: center;
  justify-content: center;
  font-size: 22rpx;
  font-weight: 700;
  flex-shrink: 0;
  border: 2rpx solid rgba(232, 114, 42, 0.2);
}

.tip-content {
  font-size: 26rpx;
  color: var(--color-text-secondary);
  line-height: 1.5;
  letter-spacing: 0.5rpx;
}

/* 动画 */
@keyframes fadeInUp {
  from {
    opacity: 0;
    transform: translateY(30rpx);
  }
  to {
    opacity: 1;
    transform: translateY(0);
  }
}

@keyframes pulse {
  0%, 100% {
    opacity: 0.4;
    transform: scale(1);
  }
  50% {
    opacity: 0.8;
    transform: scale(1.02);
  }
}

@keyframes spin {
  0% { transform: rotate(0deg); }
  100% { transform: rotate(360deg); }
}
