/* 全局样式 - 温暖有机美食风格 */

/* 设计变量 */
page {
  --color-primary: #E8722A;
  --color-primary-light: #F5A623;
  --color-primary-dark: #D4600E;
  --color-secondary: #8B5E3C;
  --color-accent: #2D5016;
  --color-background: #FBF7F4;
  --color-surface: #FFFFFF;
  --color-text-primary: #2C1810;
  --color-text-secondary: #6B5B4E;
  --color-text-muted: #A89888;
  --color-border: #E8DED5;
  --color-success: #4CAF50;
  --color-warning: #FF9800;
  --color-error: #F44336;
  
  --shadow-sm: 0 2rpx 8rpx rgba(44, 24, 16, 0.04);
  --shadow-md: 0 8rpx 24rpx rgba(44, 24, 16, 0.08);
  --shadow-lg: 0 16rpx 48rpx rgba(44, 24, 16, 0.12);
  --shadow-xl: 0 24rpx 64rpx rgba(44, 24, 16, 0.16);
  
  --radius-sm: 12rpx;
  --radius-md: 20rpx;
  --radius-lg: 28rpx;
  --radius-xl: 40rpx;
  
  background-color: var(--color-background);
  font-family: -apple-system, BlinkMacSystemFont, 'PingFang SC', 'Hiragino Sans GB', 'Microsoft YaHei', sans-serif;
  color: var(--color-text-primary);
  line-height: 1.6;
  font-size: 28rpx;
}

/* 全局容器 */
.container {
  padding: 24rpx 32rpx;
  min-height: 100vh;
}

/* 卡片样式 */
.card {
  background: var(--color-surface);
  border-radius: var(--radius-lg);
  padding: 28rpx;
  margin-bottom: 24rpx;
  box-shadow: var(--shadow-md);
  border: 2rpx solid var(--color-border);
  transition: all 0.3s ease;
}

.card:active {
  transform: scale(0.98);
  box-shadow: var(--shadow-sm);
}

/* 主按钮 */
.btn-primary {
  background: linear-gradient(135deg, var(--color-primary) 0%, var(--color-primary-light) 100%);
  color: #fff;
  border-radius: var(--radius-xl);
  padding: 24rpx 48rpx;
  font-size: 30rpx;
  font-weight: 600;
  text-align: center;
  border: none;
  box-shadow: var(--shadow-lg);
  letter-spacing: 2rpx;
  transition: all 0.3s ease;
  position: relative;
  overflow: hidden;
}

.btn-primary::before {
  content: '';
  position: absolute;
  top: 0;
  left: 0;
  right: 0;
  bottom: 0;
  background: linear-gradient(135deg, rgba(255,255,255,0.2) 0%, transparent 100%);
}

.btn-primary:active {
  opacity: 0.9;
  transform: scale(0.98);
  box-shadow: var(--shadow-md);
}

/* 次要按钮 */
.btn-secondary {
  background: var(--color-surface);
  color: var(--color-primary);
  border: 2rpx solid var(--color-primary);
  border-radius: var(--radius-xl);
  padding: 22rpx 46rpx;
  font-size: 30rpx;
  font-weight: 600;
  text-align: center;
  letter-spacing: 2rpx;
  transition: all 0.3s ease;
}

.btn-secondary:active {
  background: rgba(232, 114, 42, 0.1);
  transform: scale(0.98);
}

/* 标签样式 */
.tag {
  display: inline-flex;
  align-items: center;
  background: linear-gradient(135deg, #FFF3E0, #FFE0B2);
  color: var(--color-primary-dark);
  padding: 8rpx 18rpx;
  border-radius: var(--radius-sm);
  font-size: 22rpx;
  font-weight: 500;
  letter-spacing: 0.5rpx;
  border: 1rpx solid rgba(232, 114, 42, 0.2);
}

.tag-success {
  background: linear-gradient(135deg, #E8F5E9, #C8E6C9);
  color: #2E7D32;
  border-color: rgba(76, 175, 80, 0.2);
}

.tag-warning {
  background: linear-gradient(135deg, #FFF3E0, #FFE0B2);
  color: #E65100;
  border-color: rgba(255, 152, 0, 0.2);
}

.tag-error {
  background: linear-gradient(135deg, #FFEBEE, #FFCDD2);
  color: #C62828;
  border-color: rgba(244, 67, 54, 0.2);
}

/* 文本省略 */
.ellipsis {
  overflow: hidden;
  text-overflow: ellipsis;
  white-space: nowrap;
}

.ellipsis-2 {
  display: -webkit-box;
  -webkit-line-clamp: 2;
  -webkit-box-orient: vertical;
  overflow: hidden;
}

/* 动画 */
@keyframes fadeInUp {
  from {
    opacity: 0;
    transform: translateY(30rpx);
  }
  to {
    opacity: 1;
    transform: translateY(0);
  }
}

@keyframes fadeIn {
  from { opacity: 0; }
  to { opacity: 1; }
}

@keyframes slideUp {
  from {
    opacity: 0;
    transform: translateY(100%);
  }
  to {
    opacity: 1;
    transform: translateY(0);
  }
}

@keyframes pulse {
  0%, 100% { transform: scale(1); }
  50% { transform: scale(1.05); }
}

@keyframes spin {
  0% { transform: rotate(0deg); }
  100% { transform: rotate(360deg); }
}

@keyframes shimmer {
  0% { background-position: -200% 0; }
  100% { background-position: 200% 0; }
}

@keyframes bounceIn {
  0% {
    opacity: 0;
    transform: scale(0.3);
  }
  50% {
    opacity: 0.9;
    transform: scale(1.1);
  }
  80% {
    transform: scale(0.9);
  }
  100% {
    opacity: 1;
    transform: scale(1);
  }
}

/* 加载动画 */
.loading-spinner {
  width: 48rpx;
  height: 48rpx;
  border: 4rpx solid var(--color-border);
  border-top: 4rpx solid var(--color-primary);
  border-radius: 50%;
  animation: spin 1s linear infinite;
}

/* 空状态 */
.empty-state {
  display: flex;
  flex-direction: column;
  align-items: center;
  justify-content: center;
  padding: 80rpx 40rpx;
  color: var(--color-text-muted);
}

.empty-state image {
  width: 200rpx;
  height: 200rpx;
  margin-bottom: 24rpx;
  opacity: 0.5;
}

.empty-state .empty-title {
  font-size: 32rpx;
  font-weight: 600;
  color: var(--color-text-secondary);
  margin-bottom: 12rpx;
}

.empty-state .empty-desc {
  font-size: 26rpx;
  color: var(--color-text-muted);
  text-align: center;
  line-height: 1.6;
}

/* ========== 触摸目标规范 ========== */
/* 所有可点击元素最小 88rpx (44pt) */
.action-btn,
.menu-item,
.tag-item,
.btn-favorite,
.btn-nutrition,
.food-actions,
.item-action,
.item-delete,
.modal-close,
.preference-close,
.fab-button {
  min-height: 88rpx;
  min-width: 88rpx;
  display: flex;
  align-items: center;
  justify-content: center;
}

/* ========== 标题行（带图标） ========== */
.section-title-row,
.create-title-row {
  display: flex;
  align-items: center;
  gap: 12rpx;
  margin-bottom: 24rpx;
}

.section-title-row .section-title,
.create-title-row .create-title {
  font-size: 34rpx;
  font-weight: 700;
  color: var(--color-text-primary);
}

/* ========== 营养指标行 ========== */
.total-nutrition {
  display: flex;
  gap: 20rpx;
  flex-wrap: wrap;
}

.total-item {
  display: flex;
  align-items: center;
  gap: 8rpx;
  font-size: 24rpx;
  color: var(--color-primary);
  font-weight: 600;
}
