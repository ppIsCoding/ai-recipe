/* 菜谱卡片组件样式 */

:host {
  display: block;
}

.recipe-card {
  display: flex;
  background: var(--color-surface, #fff);
  border-radius: var(--radius-lg, 28rpx);
  padding: 24rpx;
  box-shadow: var(--shadow-md, 0 8rpx 24rpx rgba(44, 24, 16, 0.08));
  transition: all 0.3s ease;
  border: 2rpx solid var(--color-border, #E8DED5);
}

.recipe-card:active {
  transform: scale(0.98);
  box-shadow: var(--shadow-sm, 0 2rpx 8rpx rgba(44, 24, 16, 0.04));
}

.recipe-card__image {
  width: 200rpx;
  height: 200rpx;
  border-radius: var(--radius-md, 20rpx);
  margin-right: 24rpx;
  background: linear-gradient(135deg, #f5f5f5, #e8e8e8);
  flex-shrink: 0;
}

.recipe-card__content {
  flex: 1;
  display: flex;
  flex-direction: column;
  justify-content: space-between;
  padding: 4rpx 0;
}

.recipe-card__name {
  font-size: 32rpx;
  font-weight: 700;
  color: var(--color-text-primary, #2C1810);
  margin-bottom: 12rpx;
  letter-spacing: 1rpx;
  line-height: 1.3;
}

.recipe-card__desc {
  font-size: 24rpx;
  color: var(--color-text-secondary, #6B5B4E);
  margin-bottom: 16rpx;
  line-height: 1.6;
  letter-spacing: 0.5rpx;
  display: -webkit-box;
  -webkit-line-clamp: 2;
  -webkit-box-orient: vertical;
  overflow: hidden;
}

.recipe-card__meta {
  display: flex;
  flex-wrap: wrap;
  gap: 12rpx;
}

.recipe-card__tag {
  display: inline-flex;
  align-items: center;
  background: linear-gradient(135deg, #FFF3E0, #FFE0B2);
  color: var(--color-primary-dark, #D4600E);
  padding: 8rpx 18rpx;
  border-radius: var(--radius-sm, 12rpx);
  font-size: 22rpx;
  font-weight: 500;
  letter-spacing: 0.5rpx;
  border: 1rpx solid rgba(232, 114, 42, 0.2);
}

.recipe-card__match {
  display: inline-flex;
  align-items: center;
  background: linear-gradient(135deg, #E8F5E9, #C8E6C9);
  color: #2E7D32;
  padding: 8rpx 18rpx;
  border-radius: var(--radius-sm, 12rpx);
  font-size: 22rpx;
  font-weight: 500;
  letter-spacing: 0.5rpx;
  border: 1rpx solid rgba(76, 175, 80, 0.2);
}
